# ============================================================
# STAGE 1: Builder
# Full node image for compilation (Next.js needs build tools)
# ============================================================
FROM node:20-alpine AS builder
# Check https://github.com/nodejs/docker-node/tree/b4117f9333da4138b03a546ec926ef50a31506c3#nodealpine to understand why libc6-compat might be needed.
RUN apk add --no-cache libc6-compat
WORKDIR /app

# Next.js bakes NEXT_PUBLIC_* vars into the JS bundle at build time — must be ARG
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

# Leverage Docker layer cache: only re-install if package.json changes
COPY package*.json ./
RUN npm install --legacy-peer-deps

# Copy source and build
COPY . .
# Standalone mode requires this env during build
ENV NEXT_PRIVATE_STANDALONE=true
RUN npm run build

# ============================================================
# STAGE 2: Runner (Ultra-Lightweight Alpine)
# Uses Next.js standalone output — NO node_modules needed
# ============================================================
FROM node:20-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV TZ=Asia/Dhaka
# Important for Next.js standalone on Alpine
ENV PORT=3000

# Install curl for healthcheck
RUN apk add --no-cache curl

# Copy ONLY what Next.js standalone output needs
# See: https://nextjs.org/docs/pages/api-reference/next-config-js/output#automatically-copying-traced-files
COPY --from=builder /app/public ./public
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static

EXPOSE 3000

# Healthcheck
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:3000/ || exit 1

# Standalone server.js is generated by Next.js in /app/.next/standalone
CMD ["node", "server.js"]
